# .env.example - Environment Variables Template

# Rename this file to .env untuk development
# atau .env.production untuk production

# ===== Application Settings =====
VITE_APP_NAME=Alumni Tracker UMM
VITE_APP_VERSION=1.0.0

# ===== API Configuration =====
# Untuk development (localStorage only)
VITE_API_URL=http://localhost:3000

# ===== Database Configuration =====
# Note: Currently using localStorage
# Untuk future integration dengan backend API
VITE_DB_HOST=localhost
VITE_DB_PORT=5432

# ===== Feature Flags =====
VITE_ENABLE_DEMO_ACCOUNTS=true
VITE_ENABLE_EXPORT=false
VITE_ENABLE_NOTIFICATIONS=false

# ===== Analytics & Monitoring =====
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# ===== Development Settings =====
VITE_DEBUG_MODE=false
VITE_VERBOSE_LOGS=false

# ===== Storage Configuration =====
VITE_STORAGE_TYPE=localStorage
VITE_STORAGE_PREFIX=alumni_tracker_
